# Cloudflare R2 upload settings.
# Copy this file to .env and fill in the values.
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=<access-key-id>
R2_SECRET_ACCESS_KEY=<secret-access-key>
R2_BUCKET=<bucket-name>
R2_PUBLIC_BASE_URL=https://<public-r2-domain>
R2_KEY_PREFIX=vrchat
R2_CACHE_CONTROL=public, max-age=86400
R2_UPLOAD_TIMEOUT_SECONDS=600

# Optional service settings.
ADDR=:8090
PUBLIC_BASE_URL=http://localhost:8090
DATA_DIR=data
MAX_CONCURRENT_JOBS=1
JOB_TIMEOUT_MINUTES=90

# Optional Bilibili login cookie. Keep this server-side only.
# Example: BILIBILI_COOKIE="SESSDATA=...; bili_jct=...; DedeUserID=..."
BILIBILI_COOKIE=

# Optional Bilibili quality preference.
# qn=80 is 1080P, qn=64 is 720P. The service tries fallbacks in order.
BILIBILI_QUALITY=80
BILIBILI_QUALITY_FALLBACKS=80,64,32,16
